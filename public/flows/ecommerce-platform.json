{
  "meta": {
    "title": "E-Commerce Order Platform",
    "description": "Complete order processing flow from customer checkout through payment, inventory reservation, and fan-out notifications."
  },
  "layout": { "grid": { "cols": 20, "rows": 10 } },
  "zones": [
    {
      "id": "z_clients",
      "label": "Clients",
      "color": "#2d6a9f",
      "bounds": { "col": 0, "row": 1, "width": 3, "height": 8 },
      "meta": { "description": "Browser and mobile clients. Traffic enters the system here via HTTPS." }
    },
    {
      "id": "z_aws",
      "label": "AWS Cloud",
      "color": "#d45b00",
      "outline": "dashed",
      "bounds": { "col": 3, "row": 0, "width": 17, "height": 10 },
      "meta": {
        "description": "AWS us-east-1 region. All services run inside a VPC with private subnets.",
        "notes": "Auto-scaling enabled. CloudWatch alarms configured for p99 latency > 500ms."
      }
    },
    {
      "id": "z_api",
      "label": "API Layer",
      "color": "#2d9f6a",
      "parentId": "z_aws",
      "bounds": { "col": 4, "row": 2, "width": 3, "height": 6 },
      "meta": { "description": "API Gateway handles rate-limiting, JWT verification, and routing to downstream services." }
    },
    {
      "id": "z_services",
      "label": "Core Services",
      "color": "#7a3d9f",
      "parentId": "z_aws",
      "bounds": { "col": 8, "row": 0, "width": 8, "height": 10 },
      "meta": { "description": "ECS Fargate cluster. Each service runs as an independent container with its own task definition." }
    },
    {
      "id": "z_external",
      "label": "External APIs",
      "color": "#9f3d3d",
      "parentId": "z_aws",
      "outline": "dashed",
      "bounds": { "col": 17, "row": 1, "width": 3, "height": 8 },
      "meta": {
        "description": "Third-party SaaS integrations called over the public internet.",
        "notes": "Failures here are non-fatal — order processing continues and retries are scheduled."
      }
    }
  ],
  "components": [
    {
      "id": "mobile",
      "label": "Mobile App",
      "type": "client",
      "icon": "mobileScreen",
      "position": { "col": 1, "row": 2 },
      "meta": { "description": "iOS and Android checkout client" }
    },
    {
      "id": "browser",
      "label": "Web Browser",
      "type": "client",
      "logo": "react",
      "position": { "col": 1, "row": 6 },
      "meta": { "description": "React SPA served via CDN" }
    },
    {
      "id": "api_gw",
      "label": "API Gateway",
      "type": "service",
      "shape": "router",
      "color": "#1e6b4a",
      "position": { "col": 5, "row": 4 },
      "meta": { "description": "Rate-limiting, auth, and routing" }
    },
    {
      "id": "auth_svc",
      "label": "Auth Service",
      "type": "service",
      "position": { "col": 9, "row": 1 },
      "size": { "w": 2, "h": 1 },
      "meta": { "description": "JWT validation and session management", "file": "services/auth/handler.ts" }
    },
    {
      "id": "order_svc",
      "label": "Order Service",
      "type": "service",
      "color": "#1a7040",
      "position": { "col": 9, "row": 4 },
      "size": { "w": 2, "h": 1 },
      "meta": { "description": "Core order lifecycle orchestration", "file": "services/orders/index.ts" }
    },
    {
      "id": "inventory_svc",
      "label": "Inventory",
      "type": "service",
      "position": { "col": 12, "row": 7 },
      "size": { "w": 2, "h": 1 },
      "meta": { "description": "Stock reservation and availability", "file": "services/inventory/reserve.ts" }
    },
    {
      "id": "payment_fn",
      "label": "Payment Fn",
      "type": "function",
      "position": { "col": 12, "row": 1 },
      "meta": { "description": "Serverless function — charge and refund", "file": "functions/payment/charge.ts" }
    },
    {
      "id": "notif_fn",
      "label": "Notification Fn",
      "type": "function",
      "position": { "col": 14, "row": 5 },
      "meta": { "description": "Fan-out to email, Slack, and push", "file": "functions/notifications/dispatch.ts" }
    },
    {
      "id": "order_db",
      "label": "Orders DB",
      "type": "database",
      "logo": "postgresql",
      "color": "#b07520",
      "position": { "col": 12, "row": 4 },
      "meta": { "description": "PostgreSQL — order records, line items" }
    },
    {
      "id": "event_bus",
      "label": "Event Bus",
      "type": "queue",
      "position": { "col": 9, "row": 7 },
      "size": { "w": 2, "h": 1 },
      "meta": { "description": "Kafka topic: order.completed" }
    },
    {
      "id": "stripe_api",
      "label": "Stripe",
      "type": "external",
      "logo": "stripe",
      "color": "#635BFF",
      "position": { "col": 18, "row": 2 },
      "meta": { "description": "Payment processing and fraud detection" }
    },
    {
      "id": "aws_ses",
      "label": "AWS SES",
      "type": "external",
      "logo": "aws",
      "color": "#FF9900",
      "position": { "col": 18, "row": 5 },
      "meta": { "description": "Transactional email delivery" }
    },
    {
      "id": "slack_ops",
      "label": "Slack",
      "type": "external",
      "logo": "slack",
      "color": "#4A154B",
      "position": { "col": 18, "row": 7 },
      "meta": { "description": "Ops channel alerts for high-value orders" }
    }
  ],
  "connections": [
    { "id": "c_mob_gw",      "from": "mobile",        "to": "api_gw",       "route": "auto",                         "label": "HTTPS" },
    { "id": "c_web_gw",      "from": "browser",       "to": "api_gw",       "route": [{ "col": 3, "row": 5 }],       "label": "HTTPS" },
    { "id": "c_gw_auth",     "from": "api_gw",        "to": "auth_svc",     "route": [{ "col": 7, "row": 2 }],       "label": "gRPC" },
    { "id": "c_gw_order",    "from": "api_gw",        "to": "order_svc",    "route": "auto",                         "label": "gRPC" },
    { "id": "c_order_pay",   "from": "order_svc",     "to": "payment_fn",   "route": "auto",                         "label": "invoke" },
    { "id": "c_order_db",    "from": "order_svc",     "to": "order_db",     "route": "auto",                         "label": "SQL" },
    { "id": "c_order_inv",   "from": "order_svc",     "to": "inventory_svc","route": "auto",                         "label": "reserve" },
    { "id": "c_order_bus",   "from": "order_svc",     "to": "event_bus",    "route": "auto",                         "label": "publish" },
    { "id": "c_pay_stripe",  "from": "payment_fn",    "to": "stripe_api",   "route": [{ "col": 16, "row": 1 }],      "label": "REST" },
    { "id": "c_bus_notif",   "from": "event_bus",     "to": "notif_fn",     "route": "auto",                         "label": "consume" },
    { "id": "c_notif_email", "from": "notif_fn",      "to": "aws_ses",      "route": [{ "col": 16, "row": 5 }],      "label": "SMTP" },
    { "id": "c_notif_slack", "from": "notif_fn",      "to": "slack_ops",    "route": [{ "col": 16, "row": 7 }],      "label": "Webhook" }
  ],
  "steps": [
    {
      "id": 0,
      "title": "E-Commerce Platform Overview",
      "description": "A complete order processing pipeline spanning four zones: client apps, an API gateway layer, core microservices, and external third-party APIs.",
      "highlight": [
        "mobile", "browser", "api_gw", "auth_svc", "order_svc",
        "inventory_svc", "payment_fn", "notif_fn", "order_db",
        "event_bus", "stripe_api", "aws_ses", "slack_ops"
      ],
      "active_connections": [],
      "annotations": [
        {
          "type": "callout",
          "target": "api_gw",
          "text": "All external traffic enters through the API Gateway",
          "style": "info"
        }
      ]
    },
    {
      "id": 1,
      "title": "Customer Opens Checkout — Browser",
      "description": "A customer on the web app clicks 'Place Order'. The React SPA sends a POST /orders request to the backend.",
      "highlight": ["browser", "api_gw"],
      "active_connections": ["c_web_gw"],
      "packet": {
        "connection": "c_web_gw",
        "shape": "envelope"
      },
      "annotations": [
        {
          "type": "callout",
          "target": "browser",
          "text": "POST /orders — cart contents serialised as JSON",
          "style": "info"
        }
      ]
    },
    {
      "id": 2,
      "title": "Customer Opens Checkout — Mobile",
      "description": "Simultaneously, a mobile user places an order. Both channels funnel into the same API Gateway endpoint.",
      "highlight": ["mobile", "api_gw"],
      "active_connections": ["c_mob_gw"],
      "packet": {
        "connection": "c_mob_gw",
        "shape": "envelope"
      },
      "annotations": [
        {
          "type": "callout",
          "target": "mobile",
          "text": "Same REST endpoint — gateway handles both channels identically",
          "style": "info"
        }
      ]
    },
    {
      "id": 3,
      "title": "Authenticate the Request",
      "description": "The gateway forwards the Bearer token to the Auth Service for JWT validation before any business logic runs.",
      "highlight": ["api_gw", "auth_svc"],
      "active_connections": ["c_gw_auth"],
      "packet": {
        "connection": "c_gw_auth",
        "shape": "token",
        "arrivalStyle": "success"
      },
      "annotations": [
        {
          "type": "callout",
          "target": "auth_svc",
          "text": "Token valid — user identity confirmed",
          "style": "success"
        }
      ]
    },
    {
      "id": 4,
      "title": "Route Request to Order Service",
      "description": "With the caller authenticated, the gateway forwards the full order payload to the Order Service for processing.",
      "highlight": ["api_gw", "order_svc"],
      "active_connections": ["c_gw_order"],
      "packet": {
        "connection": "c_gw_order",
        "shape": "document"
      },
      "annotations": [
        {
          "type": "callout",
          "target": "order_svc",
          "text": "Order Service begins orchestrating the fulfilment pipeline",
          "style": "info"
        }
      ]
    },
    {
      "id": 5,
      "title": "Reserve Inventory",
      "description": "Order Service calls Inventory Service to place a soft hold on the requested items before charging the customer.",
      "highlight": ["order_svc", "inventory_svc"],
      "active_connections": ["c_order_inv"],
      "packet": {
        "connection": "c_order_inv",
        "shape": "sphere",
        "arrivalStyle": "warning"
      },
      "annotations": [
        {
          "type": "callout",
          "target": "inventory_svc",
          "text": "Low stock — only 2 units remaining. Reservation succeeds but triggers a reorder alert.",
          "style": "warning"
        }
      ]
    },
    {
      "id": 6,
      "title": "Process Payment",
      "description": "With stock held, Order Service invokes the Payment serverless function to tokenise and charge the card.",
      "highlight": ["order_svc", "payment_fn"],
      "active_connections": ["c_order_pay"],
      "packet": {
        "connection": "c_order_pay",
        "shape": "token"
      }
    },
    {
      "id": 7,
      "title": "Charge via Stripe",
      "description": "The Payment function calls the Stripe Charges API. The request crosses the services boundary to an external provider.",
      "highlight": ["payment_fn", "stripe_api"],
      "active_connections": ["c_pay_stripe"],
      "camera": { "focus": "stripe_api", "zoom": 1.4 },
      "packet": {
        "connection": "c_pay_stripe",
        "shape": "sphere",
        "arrivalStyle": "success"
      },
      "annotations": [
        {
          "type": "callout",
          "target": "stripe_api",
          "text": "charge_id: ch_3Pq… — £47.99 authorised",
          "style": "success"
        }
      ]
    },
    {
      "id": 8,
      "title": "Persist the Order",
      "description": "Payment confirmed. Order Service writes the completed order record, line items, and charge reference to the Orders database.",
      "highlight": ["order_svc", "order_db"],
      "active_connections": ["c_order_db"],
      "packet": {
        "connection": "c_order_db",
        "shape": "document",
        "arrivalStyle": "success"
      },
      "annotations": [
        {
          "type": "transform",
          "target": "order_db",
          "text": "INSERT INTO orders (id, status, charge_id) VALUES (…)"
        }
      ]
    },
    {
      "id": 9,
      "title": "Publish Order Completed Event",
      "description": "Order Service publishes an 'order.completed' message to the Event Bus, decoupling itself from downstream notification logic.",
      "highlight": ["order_svc", "event_bus"],
      "active_connections": ["c_order_bus"],
      "packet": {
        "connection": "c_order_bus",
        "shape": "blob"
      },
      "annotations": [
        {
          "type": "transform",
          "target": "event_bus",
          "text": "order.completed"
        }
      ]
    },
    {
      "id": 10,
      "title": "Notification Function Consumes Event",
      "description": "The Notification serverless function is triggered by the Event Bus message and prepares the fan-out dispatch list.",
      "highlight": ["event_bus", "notif_fn"],
      "active_connections": ["c_bus_notif"],
      "packet": {
        "connection": "c_bus_notif",
        "shape": "blob"
      },
      "annotations": [
        {
          "type": "callout",
          "target": "notif_fn",
          "text": "Dispatching to 2 channels: email confirmation + Slack ops alert",
          "style": "info"
        }
      ]
    },
    {
      "id": 11,
      "title": "Fan-Out: Email and Slack",
      "description": "The Notification function fires both outbound calls in parallel — a confirmation email via AWS SES and a high-value alert to the Slack ops channel.",
      "highlight": ["notif_fn", "aws_ses", "slack_ops"],
      "active_connections": ["c_notif_email", "c_notif_slack"],
      "camera": { "focus": "notif_fn", "zoom": 1.3 },
      "packets": [
        { "connection": "c_notif_email", "shape": "envelope", "arrivalStyle": "success" },
        { "connection": "c_notif_slack", "shape": "envelope", "arrivalStyle": "success" }
      ],
      "annotations": [
        {
          "type": "callout",
          "target": "aws_ses",
          "text": "Order confirmation email delivered",
          "style": "success"
        }
      ]
    },
    {
      "id": 12,
      "title": "Order Fully Confirmed",
      "description": "The entire pipeline has completed successfully. The customer receives their confirmation email, ops are notified, and inventory is reserved.",
      "highlight": [
        "mobile", "browser", "api_gw", "order_svc", "order_db",
        "inventory_svc", "payment_fn", "stripe_api",
        "event_bus", "notif_fn", "aws_ses", "slack_ops"
      ],
      "active_connections": [
        "c_mob_gw", "c_web_gw", "c_order_db", "c_notif_email", "c_notif_slack"
      ],
      "annotations": [
        {
          "type": "callout",
          "target": "order_svc",
          "text": "Order #ORD-8821 fully processed — payment captured, stock reserved, customer notified",
          "style": "success"
        }
      ]
    }
  ]
}
