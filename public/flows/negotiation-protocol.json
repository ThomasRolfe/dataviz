{
  "meta": {
    "title": "Negotiation Protocol",
    "description": "Order service and inventory service negotiate availability and pricing across multiple rounds until agreement is reached."
  },
  "layout": {
    "grid": { "cols": 12, "rows": 8 }
  },
  "zones": [
    {
      "id": "zone_orders",
      "label": "Order Domain",
      "color": "#1e3a5f",
      "bounds": { "col": 0, "row": 1, "width": 4, "height": 6 }
    },
    {
      "id": "zone_inventory",
      "label": "Inventory Domain",
      "color": "#1a3a1a",
      "bounds": { "col": 8, "row": 1, "width": 4, "height": 6 }
    }
  ],
  "components": [
    {
      "id": "client",
      "label": "Customer",
      "type": "client",
      "shape": "smartphone",
      "color": "#546e7a",
      "position": { "col": 1, "row": 2 }
    },
    {
      "id": "order_svc",
      "label": "Order Service",
      "type": "service",
      "color": "#1565c0",
      "position": { "col": 2, "row": 4 },
      "meta": { "description": "Orchestrates order fulfilment and drives the negotiation loop with Inventory." }
    },
    {
      "id": "order_db",
      "label": "Orders DB",
      "type": "database",
      "color": "#0d47a1",
      "position": { "col": 1, "row": 6 }
    },
    {
      "id": "inventory_svc",
      "label": "Inventory Service",
      "type": "service",
      "color": "#2e7d32",
      "position": { "col": 9, "row": 4 },
      "meta": { "description": "Manages stock levels and responds to availability queries." }
    },
    {
      "id": "inventory_db",
      "label": "Inventory DB",
      "type": "database",
      "color": "#1b5e20",
      "position": { "col": 10, "row": 6 }
    },
    {
      "id": "pricing_fn",
      "label": "Pricing Engine",
      "type": "function",
      "color": "#6a1b9a",
      "position": { "col": 6, "row": 2 },
      "meta": { "description": "Calculates dynamic prices based on demand and inventory signals." }
    },
    {
      "id": "event_bus",
      "label": "Event Bus",
      "type": "queue",
      "logo": "aws",
      "color": "#e65100",
      "position": { "col": 6, "row": 5 }
    }
  ],
  "connections": [
    { "id": "c_client_order",    "from": "client",        "to": "order_svc",      "label": "Place Order",       "route": "auto" },
    { "id": "c_order_inv",       "from": "order_svc",     "to": "inventory_svc",  "label": "Availability Query","route": "auto" },
    { "id": "c_order_db",        "from": "order_svc",     "to": "order_db",       "label": "Persist",           "route": "auto" },
    { "id": "c_inv_db",          "from": "inventory_svc", "to": "inventory_db",   "label": "Read Stock",        "route": "auto" },
    { "id": "c_order_pricing",   "from": "order_svc",     "to": "pricing_fn",     "label": "Price Request",     "route": "auto" },
    { "id": "c_inv_event",       "from": "inventory_svc", "to": "event_bus",      "label": "Stock Event",       "route": "auto" },
    { "id": "c_event_order",     "from": "event_bus",     "to": "order_svc",      "label": "Stock Update",      "route": "auto" }
  ],
  "steps": [
    {
      "id": 1,
      "title": "Customer Places Order",
      "description": "A customer submits an order for 50 units of product SKU-9821.",
      "highlight": ["client", "order_svc"],
      "active_connections": ["c_client_order"],
      "packet": { "connection": "c_client_order", "shape": "document" }
    },
    {
      "id": 2,
      "title": "Order Persisted (Pending)",
      "description": "Order Service writes a PENDING record to the Orders DB before starting negotiation.",
      "highlight": ["order_svc", "order_db"],
      "active_connections": ["c_order_db"],
      "packet": { "connection": "c_order_db", "shape": "token" }
    },
    {
      "id": 3,
      "title": "Round 1 — Availability Query",
      "description": "Order Service asks Inventory Service: can you fulfil 50 units at the current list price?",
      "highlight": ["order_svc", "inventory_svc"],
      "active_connections": ["c_order_inv"],
      "packet": { "connection": "c_order_inv", "shape": "envelope" }
    },
    {
      "id": 4,
      "title": "Inventory Checks Stock",
      "description": "Inventory Service reads current stock levels from the Inventory DB — only 30 units available.",
      "highlight": ["inventory_svc", "inventory_db"],
      "active_connections": ["c_inv_db"],
      "annotations": [
        { "type": "callout", "target": "inventory_db", "text": "Stock: 30 / 50 requested", "style": "warning" }
      ],
      "packet": { "connection": "c_inv_db", "shape": "token" }
    },
    {
      "id": 5,
      "title": "Round 1 — Partial Availability Response",
      "description": "Inventory replies: only 30 units available. Order Service must decide whether to accept partial fulfilment or request alternatives.",
      "highlight": ["inventory_svc", "order_svc"],
      "active_connections": ["c_order_inv"],
      "annotations": [
        { "type": "callout", "target": "inventory_svc", "text": "Can supply: 30 units", "style": "warning" }
      ],
      "packet": { "connection": "c_order_inv", "shape": "envelope", "direction": "reverse", "arrivalStyle": "warning" }
    },
    {
      "id": 6,
      "title": "Order Service Requests Dynamic Pricing",
      "description": "With partial stock confirmed, Order Service calls the Pricing Engine to check if a discounted price would unlock more inventory.",
      "highlight": ["order_svc", "pricing_fn"],
      "active_connections": ["c_order_pricing"],
      "packet": { "connection": "c_order_pricing", "shape": "sphere" }
    },
    {
      "id": 7,
      "title": "Pricing Engine Returns Discount Offer",
      "description": "Pricing Engine calculates a 12 % discount tier that may trigger a stock release from the supplier queue.",
      "highlight": ["pricing_fn", "order_svc"],
      "active_connections": ["c_order_pricing"],
      "annotations": [
        { "type": "callout", "target": "pricing_fn", "text": "Offer: −12 % at 40 units", "style": "info" }
      ],
      "packet": { "connection": "c_order_pricing", "shape": "sphere", "direction": "reverse" }
    },
    {
      "id": 8,
      "title": "Round 2 — Counter-offer Sent",
      "description": "Order Service sends a counter-offer: 40 units at the discounted rate. Inventory evaluates whether it can commit.",
      "highlight": ["order_svc", "inventory_svc"],
      "active_connections": ["c_order_inv"],
      "packet": { "connection": "c_order_inv", "shape": "document" }
    },
    {
      "id": 9,
      "title": "Inventory Publishes Stock Event",
      "description": "Inventory Service signals the Event Bus that 10 additional units were released from the safety buffer.",
      "highlight": ["inventory_svc", "event_bus"],
      "active_connections": ["c_inv_event"],
      "packet": { "connection": "c_inv_event", "shape": "blob" }
    },
    {
      "id": 10,
      "title": "Event Bus Notifies Order Service",
      "description": "The stock-released event flows back to Order Service, confirming 40 units are now reservable.",
      "highlight": ["event_bus", "order_svc"],
      "active_connections": ["c_event_order"],
      "packet": { "connection": "c_event_order", "shape": "blob", "arrivalStyle": "success" }
    },
    {
      "id": 11,
      "title": "Round 2 — Agreement Reached",
      "description": "Inventory confirms: 40 units committed at the discount price. Negotiation concludes successfully.",
      "highlight": ["inventory_svc", "order_svc"],
      "active_connections": ["c_order_inv"],
      "annotations": [
        { "type": "callout", "target": "inventory_svc", "text": "Committed: 40 units ✓", "style": "success" }
      ],
      "packet": { "connection": "c_order_inv", "shape": "document", "direction": "reverse", "arrivalStyle": "success" }
    },
    {
      "id": 12,
      "title": "Order Confirmed",
      "description": "Order Service updates the Orders DB: status CONFIRMED, quantity 40, discount applied.",
      "highlight": ["order_svc", "order_db"],
      "active_connections": ["c_order_db"],
      "annotations": [
        { "type": "transform", "target": "order_svc", "text": "Status → CONFIRMED", "style": "success" }
      ],
      "packet": { "connection": "c_order_db", "shape": "document", "arrivalStyle": "success" }
    },
    {
      "id": 13,
      "title": "Confirmation Returned to Customer",
      "description": "Order Service sends the final confirmation back to the customer: order accepted, ships in 2 days.",
      "highlight": ["order_svc", "client"],
      "active_connections": ["c_client_order"],
      "annotations": [
        { "type": "callout", "target": "client", "text": "Order confirmed — ships in 2 days", "style": "success" }
      ],
      "packet": { "connection": "c_client_order", "shape": "document", "direction": "reverse", "arrivalStyle": "success" }
    }
  ]
}
